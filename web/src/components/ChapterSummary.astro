---
export interface Props {
  title?: string;
  summary?: string;
  keyTakeaways?: string[];
}

const { title, summary, keyTakeaways } = Astro.props;
---

<div class="chapter-summary border-l-4 border-blue-500 bg-blue-50 p-4 mb-6 rounded-r-lg">
  {title && <h3 class="text-lg font-semibold text-blue-800 mb-2">{title}</h3>}
  {summary && <p class="text-gray-700 mb-2">{summary}</p>}
  {keyTakeaways && keyTakeaways.length > 0 && (
    <div>
      <h4 class="text-sm font-semibold text-blue-700 mb-1">Key Takeaways</h4>
      <ul class="list-disc list-inside text-gray-600 text-sm">
        {keyTakeaways.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  )}
</div>
