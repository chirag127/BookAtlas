---
export interface Props {
  title?: string;
  questions?: string[];
  activities?: string[];
}

const { title, questions, activities } = Astro.props;
---

<div class="reading-guide bg-green-50 border-l-4 border-green-500 p-4 mb-6 rounded-r-lg">
  {title && <h3 class="text-lg font-semibold text-green-800 mb-2">{title}</h3>}
  {questions && questions.length > 0 && (
    <div class="mb-3">
      <h4 class="text-sm font-semibold text-green-700 mb-1">Reflection Questions</h4>
      <ul class="list-disc list-inside text-gray-600 text-sm">
        {questions.map((q) => <li>{q}</li>)}
      </ul>
    </div>
  )}
  {activities && activities.length > 0 && (
    <div>
      <h4 class="text-sm font-semibold text-green-700 mb-1">Activities</h4>
      <ul class="list-disc list-inside text-gray-600 text-sm">
        {activities.map((a) => <li>{a}</li>)}
      </ul>
    </div>
  )}
</div>
